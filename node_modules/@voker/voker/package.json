{
    "name": "@voker/voker",
    "version": "0.0.10",
    "description": "",
    "types": "./dist/index.d.ts",
    "main": "./dist/index.cjs",
    "type": "module",
    "exports": {
        "./schema/base": {
            "types": "./dist/schema/base/index.d.ts",
            "import": "./dist/schema/base/index.js",
            "require": "./dist/schema/base/index.cjs"
        },
        "./ai/*": {
            "types": "./dist/ai/*/index.d.ts",
            "import": "./dist/ai/*/index.js",
            "require": "./dist/ai/*/index.cjs"
        },
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup src/index.ts src/schema/base/index.ts src/ai/*/index.ts --format esm,cjs --dts --out-dir dist",
        "test": "echo \"Error: no test specified\" && exit 1",
        "test-run": "npm run build && node dist/index.js",
        "lint": "eslint \"src/**/*.ts\"",
        "lint:fix": "eslint \"src/**/*.ts\" --fix",
        "format": "prettier --check .",
        "format:fix": "prettier --write ."
    },
    "author": "",
    "license": "Apache-2.0",
    "devDependencies": {
        "@anthropic-ai/sdk": "^0.74.0",
        "@google/genai": "^1.41.0",
        "@typescript-eslint/eslint-plugin": "^8.46.4",
        "@typescript-eslint/parser": "^8.46.4",
        "ai": "^6.0.168",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jsdoc": "^61.2.1",
        "eslint-plugin-tsdoc": "^0.5.0",
        "openai": "^6.22.0",
        "prettier": "^3.6.2",
        "tsup": "^8.5.1",
        "typescript-eslint": "^8.46.4"
    }
}
